// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id         String      @id @map("id")
  workspaces Workspace[]

  @@map("account")
}

model Workspace {
  id          String          @id @map("id")
  accountId   String          @map("account_id")
  permit      String          @default("owner") @map("permit")
  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  pages       Page[]
  pinnedPages PinnedPages?
  bridges     BridgeResource[]

  @@index([accountId])
  @@map("workspace")
}

model Page {
  id          String      @id @map("id")
  workspaceId String      @map("workspace_id")
  title       String      @map("title")
  icon        String?     @db.VarChar(256) @map("icon")
  cover       String?     @map("cover")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  blocks      Block[]

  @@index([workspaceId])
  @@map("page")
}

model Block {
  id        String   @id @map("id")
  pageId    String   @map("page_id")
  type      String   @map("type")
  content   String   @default("") @map("content")
  position  Int      @default(0) @map("position")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([pageId, position])
  @@map("block")
}

model PinnedPages {
  id         String    @id @map("id")
  workspaceId String   @unique @map("workspace_id")
  pageIds    Json      @map("page_ids")
  orderBy    String    @default("custom") @map("order_by")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("pinned_pages")
}

model BridgeResource {
  id               String    @id @map("id")
  workspaceId      String    @map("workspace_id")
  name             String    @default("") @map("name")
  bridgeType       String    @map("bridge_type")
  endpoint         String    @default("") @map("endpoint")
  environment      String    @default("development") @map("environment")
  method           String?   @map("method")
  apiConfig        Json?     @map("api_config")
  requiredFields   Json?     @map("required_fields")
  serviceName      String?   @map("service_name")
  secret           String?   @map("secret")
  isPrivateInternal Boolean  @default(false) @map("is_private_internal")
  privateNote      String?   @map("private_note")
  publicNote       String?   @map("public_note")
  notes            String?   @map("notes")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("bridges")
}
